      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import groovy.json.JsonOutput
import java.util.concurrent.ConcurrentHashMap

def DT_URL   = vars.get(&quot;DT_URL&quot;)
def DT_TOKEN = vars.get(&quot;DT_TOKEN&quot;)

try {
    log.info(&quot;=== tearDown: Script started ===&quot;)

    long   endEpoch   = System.currentTimeMillis()
    String endTime    = new Date(endEpoch).format(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    long   startEpoch = Long.parseLong(props.get(&quot;TEST_START_EPOCH&quot;) ?: &quot;0&quot;)
    long   durationMs = endEpoch - startEpoch

    log.info(&quot;TEST_PLAN_NAME  = &quot; + props.get(&quot;TEST_PLAN_NAME&quot;))
    log.info(&quot;TEST_START_TIME = &quot; + props.get(&quot;TEST_START_TIME&quot;))
    log.info(&quot;TEST_END_TIME   = &quot; + endTime)

	// ── Read Thread Group properties from ctx ────────────────
	def numThreads = Integer.parseInt(props.get(&quot;THREAD_NUM_THREADS&quot;) ?: &quot;0&quot;)
	def rampUp     = Integer.parseInt(props.get(&quot;THREAD_RAMP_UP&quot;)     ?: &quot;0&quot;)
	def loopCount  = Integer.parseInt(props.get(&quot;THREAD_LOOP_COUNT&quot;)  ?: &quot;0&quot;)
	def scriptName  = props.get(&quot;THREAD_GROUP_NAME&quot;) ?: &quot;N/A&quot;
	
	log.info(&quot;Thread Group → name=${scriptName} threads=${numThreads} rampup=${rampUp} loops=${loopCount}&quot;)
	// ─────────────────────────────────────────────────────────
    
	
    def statsMap = props.get(&quot;STATS_MAP&quot;) as ConcurrentHashMap
    if (!statsMap || statsMap.isEmpty()) {
        log.warn(&quot;=== STATS_MAP is empty — no results to send ===&quot;)
        SampleResult.setSuccessful(false)
        SampleResult.setResponseData(&quot;STATS_MAP empty&quot;, &quot;UTF-8&quot;)
        return
    }

    log.info(&quot;Labels in STATS_MAP: &quot; + statsMap.keySet())

    def samplerResults = []
    long grandTotal  = 0L, grandErrors = 0L
    long grandSumRT  = 0L, grandSumRT2 = 0L
    long grandMinRT  = Long.MAX_VALUE, grandMaxRT = 0L
    long grandSumB   = 0L, grandSumS   = 0L

    // Preserve insertion order
    statsMap.each { label, s -&gt;
        def total  = s[&quot;total&quot;]  as long
        def errors = s[&quot;errors&quot;] as long
        def sumRT  = s[&quot;sumRT&quot;]  as long
        def sumRT2 = s[&quot;sumRT2&quot;] as long
        def minRT  = s[&quot;minRT&quot;]  as long
        def maxRT  = s[&quot;maxRT&quot;]  as long
        def sumB   = s[&quot;sumB&quot;]   as long
        def sumS   = s[&quot;sumS&quot;]   as long

        def avgRT  = total &gt; 0 ? (long)(sumRT / total) : 0L
        def errPct = total &gt; 0 ? String.format(&quot;%.2f&quot;, (errors / total) * 100) : &quot;0.00&quot;
        def avgB   = total &gt; 0 ? (long)(sumB / total)  : 0L
        def stdDev = &quot;0.00&quot;
        def tps    = &quot;0.00&quot;
        def recvKB = &quot;0.00&quot;
        def sentKB = &quot;0.00&quot;

        if (total &gt; 0) {
            double avg = (double)(sumRT / total)
            stdDev = String.format(&quot;%.2f&quot;, Math.sqrt(Math.abs(((double)sumRT2 / total) - (avg * avg))))
        }
        if (durationMs &gt; 0) {
            double elapsed = durationMs / 1000.0
            tps    = String.format(&quot;%.2f&quot;, total / elapsed)
            recvKB = String.format(&quot;%.2f&quot;, (sumB / 1024.0) / elapsed)
            sentKB = String.format(&quot;%.2f&quot;, (sumS / 1024.0) / elapsed)
        }

        log.info(&quot;Sampler [${label}] total=${total} errors=${errors} avg=${avgRT}ms min=${minRT}ms max=${maxRT}ms stddev=${stdDev} err%=${errPct} tps=${tps}&quot;)

        samplerResults &lt;&lt; [
            &quot;label&quot;           : label,
            &quot;samples&quot;         : total,
            &quot;average.ms&quot;      : avgRT,
            &quot;min.ms&quot;          : minRT == Long.MAX_VALUE ? 0 : minRT,
            &quot;max.ms&quot;          : maxRT,
            &quot;std.dev&quot;         : stdDev,
            &quot;error.percent&quot;   : errPct,
            &quot;throughput.sec&quot;  : tps,
            &quot;received.kb.sec&quot; : recvKB,
            &quot;sent.kb.sec&quot;     : sentKB,
            &quot;avg.bytes&quot;       : avgB
        ]

        grandTotal  += total;  grandErrors += errors
        grandSumRT  += sumRT;  grandSumRT2 += sumRT2
        grandMinRT   = Math.min(grandMinRT, minRT)
        grandMaxRT   = Math.max(grandMaxRT, maxRT)
        grandSumB   += sumB;   grandSumS   += sumS
    }

    // TOTAL row
    def grandAvgRT  = grandTotal &gt; 0 ? (long)(grandSumRT / grandTotal) : 0L
    def grandErrPct = grandTotal &gt; 0 ? String.format(&quot;%.2f&quot;, (grandErrors / grandTotal) * 100) : &quot;0.00&quot;
    def grandStdDev = &quot;0.00&quot;
    def grandTPS    = &quot;0.00&quot;
    def grandRecvKB = &quot;0.00&quot;
    def grandSentKB = &quot;0.00&quot;
    def grandAvgB   = grandTotal &gt; 0 ? (long)(grandSumB / grandTotal) : 0L

    if (grandTotal &gt; 0) {
        double avg  = (double)(grandSumRT / grandTotal)
        grandStdDev = String.format(&quot;%.2f&quot;, Math.sqrt(Math.abs(((double)grandSumRT2 / grandTotal) - (avg * avg))))
    }
    if (durationMs &gt; 0) {
        double elapsed = durationMs / 1000.0
        grandTPS    = String.format(&quot;%.2f&quot;, grandTotal / elapsed)
        grandRecvKB = String.format(&quot;%.2f&quot;, (grandSumB / 1024.0) / elapsed)
        grandSentKB = String.format(&quot;%.2f&quot;, (grandSumS / 1024.0) / elapsed)
    }

    log.info(&quot;TOTAL → samples=${grandTotal} avg=${grandAvgRT}ms err%=${grandErrPct} tps=${grandTPS}&quot;)

    samplerResults &lt;&lt; [
        &quot;label&quot;           : &quot;TOTAL&quot;,
        &quot;samples&quot;         : grandTotal,
        &quot;average.ms&quot;      : grandAvgRT,
        &quot;min.ms&quot;          : grandMinRT == Long.MAX_VALUE ? 0 : grandMinRT,
        &quot;max.ms&quot;          : grandMaxRT,
        &quot;std.dev&quot;         : grandStdDev,
        &quot;error.percent&quot;   : grandErrPct,
        &quot;throughput.sec&quot;  : grandTPS,
        &quot;received.kb.sec&quot; : grandRecvKB,
        &quot;sent.kb.sec&quot;     : grandSentKB,
        &quot;avg.bytes&quot;       : grandAvgB
    ]

    def payload = JsonOutput.toJson([[
        &quot;specversion&quot; : &quot;1.0&quot;,
        &quot;id&quot;          : &quot;jmeter-summary-${endEpoch}&quot;,
        &quot;source&quot;      : &quot;jmeter&quot;,
        &quot;type&quot;        : &quot;com.jmeter.test.summary&quot;,
        &quot;data&quot; : [
		    &quot;test.plan.name&quot;       : props.get(&quot;TEST_PLAN_NAME&quot;)  ?: &quot;N/A&quot;,
		    &quot;test.script.name&quot;     : scriptName,
		    &quot;test.event&quot;           : &quot;TEST_SUMMARY&quot;,
		    &quot;test.start.time&quot;      : props.get(&quot;TEST_START_TIME&quot;) ?: &quot;N/A&quot;,
		    &quot;test.start.epoch&quot;     : startEpoch,
		    &quot;test.end.time&quot;        : endTime,
		    &quot;test.end.epoch&quot;       : endEpoch,
		    &quot;test.duration.ms&quot;     : durationMs,
		    &quot;thread.num.threads&quot;   : numThreads,
	         &quot;thread.ramp.up.sec&quot;   : rampUp,
	         &quot;thread.loop.count&quot;    : loopCount,
	         &quot;thread.total.samples&quot; : numThreads * loopCount,
		    &quot;test.sampler.count&quot;   : statsMap.size(),
		    &quot;summary.rows&quot;         : samplerResults
		]
    ]])

    log.info(&quot;Payload:\n&quot; + JsonOutput.prettyPrint(payload))

    def url  = new URL(DT_URL + &quot;/api/v2/bizevents/ingest&quot;)
    def conn = (HttpURLConnection) url.openConnection()
    conn.setRequestMethod(&quot;POST&quot;)
    conn.setDoOutput(true)
    conn.setRequestProperty(&quot;Content-Type&quot;, &quot;application/cloudevents-batch+json&quot;)
    conn.setRequestProperty(&quot;Authorization&quot;, &quot;Api-Token ${DT_TOKEN}&quot;)
    conn.setConnectTimeout(10000)
    conn.setReadTimeout(10000)
    conn.outputStream.withWriter(&quot;UTF-8&quot;) { it.write(payload) }

    def responseCode = conn.responseCode
    def responseBody = responseCode &gt;= 200 &amp;&amp; responseCode &lt; 300 \
        ? conn.inputStream.text \
        : conn.errorStream?.text ?: &quot;No error body&quot;

    log.info(&quot;=== DT BizEvent SUMMARY → HTTP ${responseCode}: ${responseBody} ===&quot;)

    SampleResult.setResponseCode(String.valueOf(responseCode))
    SampleResult.setSuccessful(responseCode == 202)
    SampleResult.setResponseData(responseBody, &quot;UTF-8&quot;)

} catch (Exception e) {
    log.error(&quot;=== tearDown FAILED: ${e.getMessage()} ===&quot;)
    SampleResult.setSuccessful(false)
    SampleResult.setResponseData(e.getMessage(), &quot;UTF-8&quot;)
}</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <ResultCollector guiclass="ViewResultsFullVisualizer" testclass="ResultCollector" testname="View Results Tree" enabled="true">
          <boolProp name="ResultCollector.error_logging">false</boolProp>
          <objProp>
            <name>saveConfig</name>
            <value class="SampleSaveConfiguration">
              <time>true</time>
              <latency>true</latency>
              <timestamp>true</timestamp>
              <success>true</success>
              <label>true</label>
              <code>true</code>
              <message>true</message>
              <threadName>true</threadName>
              <dataType>true</dataType>
              <encoding>false</encoding>
              <assertions>true</assertions>
              <subresults>true</subresults>
              <responseData>false</responseData>
              <samplerData>false</samplerData>
              <xml>false</xml>
              <fieldNames>true</fieldNames>
              <responseHeaders>false</responseHeaders>
              <requestHeaders>false</requestHeaders>
              <responseDataOnError>false</responseDataOnError>
              <saveAssertionResultsFailureMessage>true</saveAssertionResultsFailureMessage>
              <assertionsResultsToSave>0</assertionsResultsToSave>
              <bytes>true</bytes>
              <sentBytes>true</sentBytes>
              <url>true</url>
              <threadCounts>true</threadCounts>
              <idleTime>true</idleTime>
              <connectTime>true</connectTime>
            </value>
          </objProp>
          <stringProp name="filename"></stringProp>
        </ResultCollector>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
