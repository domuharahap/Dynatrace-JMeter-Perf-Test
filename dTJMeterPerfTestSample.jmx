<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Test Case Name">
      <stringProp name="TestPlan.comments">This is a test case for dTPay</stringProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="TEST_PLAN_TITLE" elementType="Argument">
            <stringProp name="Argument.name">TEST_PLAN_TITLE</stringProp>
            <stringProp name="Argument.value">TestCaseName</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="DT_URL" elementType="Argument">
            <stringProp name="Argument.name">DT_URL</stringProp>
            <stringProp name="Argument.value">https://tenantId.live.dynatrace.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="DT_TOKEN" elementType="Argument">
            <stringProp name="Argument.name">DT_TOKEN</stringProp>
            <stringProp name="Argument.value">dt0c01.TOKEN</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>
      <SetupThreadGroup guiclass="SetupThreadGroupGui" testclass="SetupThreadGroup" testname="setUp Thread Group">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </SetupThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import groovy.json.JsonOutput
import java.util.concurrent.ConcurrentHashMap

def DT_URL   = vars.get(&quot;DT_URL&quot;)
def DT_TOKEN = vars.get(&quot;DT_TOKEN&quot;)

try {
    log.info(&quot;=== setUp: Creating fresh stats map ===&quot;)

    // Replace entire map with a brand new one — guaranteed clean
    def freshMap = new ConcurrentHashMap()
    props.put(&quot;STATS_MAP&quot;, freshMap)
    props.put(&quot;STATS_LOCK&quot;, new Object())

    long   startEpoch = System.currentTimeMillis()
    String startTime  = new Date(startEpoch).format(&quot;yyyy-MM-dd HH:mm:ss&quot;)
    String testPlan   = vars.get(&quot;__TestPlanName&quot;) ?: vars.get(&quot;TEST_PLAN_TITLE&quot;) ?: &quot;dTPay Test Case&quot;

    props.put(&quot;TEST_START_EPOCH&quot;, String.valueOf(startEpoch))
    props.put(&quot;TEST_START_TIME&quot;,  startTime)
    props.put(&quot;TEST_PLAN_NAME&quot;,   testPlan)

    
    log.info(&quot;=== setUp: Fresh map created. Test Start = ${startTime} ===&quot;)

    def payload = JsonOutput.toJson([[
	    &quot;specversion&quot; : &quot;1.0&quot;,
	    &quot;id&quot;          : &quot;jmeter-start-${startEpoch}&quot;,
	    &quot;source&quot;      : &quot;jmeter&quot;,
	    &quot;type&quot;        : &quot;com.jmeter.test.start&quot;,
	    &quot;data&quot;        : [
	        &quot;test.plan.name&quot;       : testPlan,
	        &quot;test.ltn&quot;             : testPlan,
	        &quot;test.event&quot;           : &quot;TEST_START&quot;,
	        &quot;test.start.time&quot;      : startTime,
	        &quot;test.start.epoch&quot;     : startEpoch
	    ]
	]])

    def url  = new URL(DT_URL + &quot;/api/v2/bizevents/ingest&quot;)
    def conn = (HttpURLConnection) url.openConnection()
    conn.setRequestMethod(&quot;POST&quot;)
    conn.setDoOutput(true)
    conn.setRequestProperty(&quot;Content-Type&quot;, &quot;application/cloudevents-batch+json&quot;)
    conn.setRequestProperty(&quot;Authorization&quot;, &quot;Api-Token ${DT_TOKEN}&quot;)
    conn.setConnectTimeout(10000)
    conn.setReadTimeout(10000)
    conn.outputStream.withWriter(&quot;UTF-8&quot;) { it.write(payload) }

    def responseCode = conn.responseCode
    def responseBody = responseCode &gt;= 200 &amp;&amp; responseCode &lt; 300 \
        ? conn.inputStream.text \
        : conn.errorStream?.text ?: &quot;No error body&quot;

    log.info(&quot;=== DT BizEvent START → HTTP ${responseCode}: ${responseBody} ===&quot;)

    SampleResult.setResponseCode(String.valueOf(responseCode))
    SampleResult.setSuccessful(responseCode == 202)
    SampleResult.setResponseData(responseBody, &quot;UTF-8&quot;)

} catch (Exception e) {
    log.error(&quot;=== setUp FAILED: ${e.getMessage()} ===&quot;)
    SampleResult.setSuccessful(false)
    SampleResult.setResponseData(e.getMessage(), &quot;UTF-8&quot;)
}</stringProp>
        </JSR223Sampler>
