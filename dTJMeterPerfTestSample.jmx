        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import java.util.Random

Random rand = new Random()

// 1. Generate Random Price (e.g., between 10.00 and 1000.00)
double minPrice = 10.00
double maxPrice = 1000.00
double randomPrice = minPrice + (maxPrice - minPrice) * rand.nextDouble()
vars.put(&quot;randomPrice&quot;, String.format(&quot;%.2f&quot;, randomPrice))

// 2. Select Random Payment Method from Array
def methods = [&quot;CreditCard&quot;, &quot;DebitCard&quot;, &quot;PayPal&quot;]
def randomMethod = methods[rand.nextInt(methods.size())]
vars.put(&quot;paymentType&quot;, randomMethod)

// 3. Generate Random Full Name (Using simple lists to mimic Postman)
def firstNames = [&quot;James&quot;, &quot;Mary&quot;, &quot;Robert&quot;, &quot;Patricia&quot;, &quot;John&quot;, &quot;Jennifer&quot;, &quot;Michael&quot;, &quot;Linda&quot;, &quot;David&quot;, &quot;Elizabeth&quot;]
def lastNames = [&quot;Smith&quot;, &quot;Johnson&quot;, &quot;Williams&quot;, &quot;Brown&quot;, &quot;Jones&quot;, &quot;Garcia&quot;, &quot;Miller&quot;, &quot;Davis&quot;, &quot;Rodriguez&quot;, &quot;Martinez&quot;]
def randomFullName = firstNames[rand.nextInt(firstNames.size())] + &quot; &quot; + lastNames[rand.nextInt(lastNames.size())]
vars.put(&quot;randomFullName&quot;, randomFullName)

// 4. Generate Random User ID (e.g., 5-digit number)
int randomUserId = rand.nextInt(90000) + 10000 
vars.put(&quot;randomUserId&quot;, randomUserId.toString())</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
        <JSR223Listener guiclass="TestBeanGUI" testclass="JSR223Listener" testname="JSR223 Listener">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.util.concurrent.ConcurrentHashMap

def result    = sampleEvent.getResult()
def label     = result.getSampleLabel()
def success   = result.isSuccessful()
def respTime  = result.getTime()
def bytes     = result.getBytesAsLong()
def sentBytes = result.getSentBytes()

// Skip setUp/tearDown BizEvent samplers
def skipLabels = [&quot;DT BizEvent - Test Start&quot;, &quot;DT BizEvent - Test End + Summary&quot;]
if (skipLabels.contains(label)) return

// Get the shared map created fresh in setUp
def statsMap = props.get(&quot;STATS_MAP&quot;)
if (statsMap == null) {
    log.warn(&quot;STATS_MAP not found — setUp may not have run&quot;)
    return
}

def lock = props.get(&quot;STATS_LOCK&quot;)
if (lock == null) return

synchronized(lock) {

	// ── Capture thread properties once on very first sample ──
    if (statsMap.isEmpty()) {
        try {
            def tg         = ctx.getThreadGroup()
            def numThreads = tg.getNumThreads()
            def rampUp     = tg.getRampUp()
            def loopCount  = tg.getSamplerController()?.getLoops() ?: 0
            def tgName     = vars.get(&quot;__threadGroupName&quot;) ?: tg.getName() ?: &quot;N/A&quot;

            props.put(&quot;THREAD_NUM_THREADS&quot;, String.valueOf(numThreads))
            props.put(&quot;THREAD_RAMP_UP&quot;,     String.valueOf(rampUp))
            props.put(&quot;THREAD_LOOP_COUNT&quot;,  String.valueOf(loopCount))
            props.put(&quot;THREAD_GROUP_NAME&quot;,  tgName)

            log.info(&quot;Thread props captured → name=${tgName} threads=${numThreads} rampup=${rampUp} loops=${loopCount}&quot;)
        } catch (Exception ex) {
            log.warn(&quot;Thread props capture failed: &quot; + ex.getMessage())
        }
    }
    // ─────────────────────────────────────────────────────────
    
    // Get or create per-label map
    if (!statsMap.containsKey(label)) {
        statsMap.put(label, new ConcurrentHashMap([
            &quot;total&quot;  : 0L, &quot;errors&quot; : 0L,
            &quot;sumRT&quot;  : 0L, &quot;sumRT2&quot; : 0L,
            &quot;minRT&quot;  : Long.MAX_VALUE,
            &quot;maxRT&quot;  : 0L,
            &quot;sumB&quot;   : 0L, &quot;sumS&quot;   : 0L
        ]))
        log.info(&quot;Registered new label: ${label}&quot;)
    }

    def s = statsMap.get(label)

    s[&quot;total&quot;]  = s[&quot;total&quot;]  + 1
    s[&quot;errors&quot;] = s[&quot;errors&quot;] + (success ? 0L : 1L)
    s[&quot;sumRT&quot;]  = s[&quot;sumRT&quot;]  + respTime
    s[&quot;sumRT2&quot;] = s[&quot;sumRT2&quot;] + (respTime * respTime)
    s[&quot;minRT&quot;]  = Math.min(s[&quot;minRT&quot;] as long, respTime)
    s[&quot;maxRT&quot;]  = Math.max(s[&quot;maxRT&quot;] as long, respTime)
    s[&quot;sumB&quot;]   = s[&quot;sumB&quot;]   + bytes
    s[&quot;sumS&quot;]   = s[&quot;sumS&quot;]   + sentBytes
}</stringProp>
        </JSR223Listener>
